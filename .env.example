# ── Textbelt SMS (https://textbelt.com) ──────────────────────────────────────
# Get a free key at textbelt.com, or use "textbelt" for 1 free SMS per day
TEXTBELT_API_KEY=your_textbelt_key_here

# ── Restaurant info ───────────────────────────────────────────────────────────
RESTAURANT_NAME=Your Restaurant Name
STAFF_PIN=1234

# ── CORS (production) ─────────────────────────────────────────────────────────
# Set to your frontend URL in production to restrict cross-origin access
# Leave unset (or omit) in development — defaults to * (all origins)
ALLOWED_ORIGIN=https://yourdomain.com

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
